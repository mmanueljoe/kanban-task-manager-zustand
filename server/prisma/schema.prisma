
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ─────────────────────────────────────────────────────────────────────────────
// Models go below. Write them here — one `model` block per table, mirroring the
// four domain entities: User, Board, Column, Task (+ the Subtask and the
// board-collaborator join table).
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}


enum CollaboratorRole {
  EDITOR
  VIEWER
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  passwordHash String
  role UserRole @default(USER)
  ownedBoards Board[]
  collaborations BoardCollaborator[]
  activities Activity[]
  assignedTasks Task[]
  comments Comment[]
  notifications Notification[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model BoardCollaborator {
  userId String
  boardId String
  role CollaboratorRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@id([boardId, userId])
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
}


model Board {
  id String @id @default(uuid())
  ownerId String
  name String
  columns Column[]
  collaborators BoardCollaborator[]
  activities Activity[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner User @relation(fields: [ownerId], references: [id])
}


model Column {
  id String @id @default(uuid())
  boardId String
  name String
  position Int
  tasks Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

model Task {
  id String @id @default(uuid())
  columnId  String
  title String
  description String @default("")
  position Int
  assignedToId String?
  subtasks Subtask[]
  comments Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  column Column @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee User? @relation(fields: [assignedToId], references: [id])
}

model Comment {
  id String @id @default(uuid())
  taskId String
  authorId String
  body String
  createdAt DateTime @default(now())
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId, createdAt])
}

model Subtask {
  id String  @id @default(uuid())
  taskId String
  title String
  isCompleted Boolean @default(false)
  position Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

enum ActivityType {
  TASK_CREATED
  TASK_MOVED
  TASK_UPDATED
  TASK_DELETED
  TASK_ASSIGNED
  COLUMN_CREATED
  COLUMN_RENAMED
  COLUMN_DELETED
  BOARD_RENAMED
  MEMBER_INVITED
  MEMBER_ROLE_CHANGED
  MEMBER_REMOVED
  COMMENT_ADDED
}

model Notification {
  id String @id @default(uuid())
  userId String
  actorId String
  type ActivityType
  boardId String
  details Json
  read Boolean @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Activity {
  id String @id @default(uuid())
  boardId String
  actorId String
  type ActivityType
  // A snapshot of the human-readable facts (e.g. task title, from/to column) as
  // they were at the time. Stored instead of joined so renaming or deleting a
  // task later never rewrites history.
  details Json
  createdAt DateTime @default(now())
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id])

  // The feed always asks "this board, newest first" — index both columns for it.
  @@index([boardId, createdAt])
}